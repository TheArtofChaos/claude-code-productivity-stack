{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Write-Output '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"💡 Project tip: run /kickoff to see available skills and get a project-tailored, token-efficient toolset recommendation (memory loop, on-demand harnesses). Skip if just continuing a quick task.\"}}'",
            "shell": "powershell",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell -ExecutionPolicy Bypass -File \"$HOME\\.claude\\plugins\\cache\\ponytail\\ponytail\\<version>\\hooks\\ponytail-statusline.ps1\""
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "ruflo-core@ruflo": false,
    "ruflo-swarm@ruflo": false,
    "obsidian@obsidian-skills": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "ponytail@ponytail": true,
    "impeccable@impeccable": true,
    "document-skills@anthropic-agent-skills": true,
    "marketing-skills@marketingskills": false,
    "social-media-skills@social-media-skills": false,
    "claude-seo@agricidaniel-claude-seo": false,
    "watch@claude-watch": true
  },
  "extraKnownMarketplaces": {
